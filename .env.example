# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
#
#   cp .env.example .env
#
# .env holds secrets + config. auth.setup.ts reads these to log in once and
# save the session to playwright/.auth/state.json. Task tests then reuse the
# saved session and never see these credentials.

# The page your task scripts start from (used as baseURL).
BASE_URL=https://my.serviceautopilot.com/

# The login page (may be the same as BASE_URL or a dedicated /login).
LOGIN_URL=https://my.serviceautopilot.com/

# Credentials used ONLY by auth.setup.ts.
SAP_USER=you@example.com
SAP_PASS=change-me

# WhatConverts API credentials (https://www.whatconverts.com/api/) — used to
# pull lead records (name/phone/email + UTM source/medium) before the SA match.
# Auth is HTTP Basic as token:secret — see WhatConverts dashboard > Integrations > API Keys.
# This is agency-level: works across every client's profile_id, not just one.
WHATCONVERTS_API_TOKEN=
WHATCONVERTS_API_SECRET=

# Restricts the single-client script's /leads pull to one profile.
# Find it via GET /api/v1/accounts/{account_id}/profiles or a lead's "profile_id" field.
WHATCONVERTS_PROFILE_ID=

# Per-client Service Autopilot logins, one pair per client key in
# config/clients.json (uppercased): SA_EMAIL_<KEY> / SA_PASSWORD_<KEY>.
# SA_EMAIL_EXAMPLE_CLIENT=you@example.com
# SA_PASSWORD_EXAMPLE_CLIENT=change-me

# SMTP settings used to email the "client not found" log to the requester.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=change-me
SMTP_FROM=you@example.com
SMTP_TO=omega@kudos.marketing

# Optional: override the WhatConverts pull range for a specific run.
# Format YYYY-MM-DD. Leave both blank to default to "yesterday".
#   START_DATE=2026-06-01 END_DATE=2026-06-30 npm run sync
# START_DATE=
# END_DATE=

# Add per-run inputs here as needed, e.g.:
# QUOTE_ID=12345
